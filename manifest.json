{
  "manifest_version": 3,
  "name": "TabVault",
  "version": "1.0.0",
  "description": "Group tabs by domain and manage your workspace efficiently.",
  "permissions": [
    "tabs",
    "tabGroups"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Open TabVault"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
